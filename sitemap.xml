---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% comment %}
    Manual sitemap (no jekyll-sitemap plugin — matches feed.xml convention).
    Emits every rendered HTML page plus all posts, with absolute URLs.
  {% endcomment %}
  {% for page in site.html_pages %}
    {% unless page.sitemap == false or page.url == "/404.html" %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    {% if page.url == "/" %}<priority>1.0</priority>{% endif %}
  </url>
    {% endunless %}
  {% endfor %}
  {% for post in site.posts %}
  <url>
    <loc>{{ site.url }}{{ post.url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
  </url>
  {% endfor %}
</urlset>
